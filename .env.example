# =============================================================================
# Codehive Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values you need.
# Only uncomment/set the variables relevant to your setup.

# ---------------------------------------------------------------------------
# Server settings
# ---------------------------------------------------------------------------
CODEHIVE_HOST=127.0.0.1
CODEHIVE_PORT=7433
CODEHIVE_DEBUG=false

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Default: SQLite (zero infrastructure needed)
# CODEHIVE_DATABASE_URL=sqlite+aiosqlite:///data/codehive.db

# For PostgreSQL (requires Docker or external server):
CODEHIVE_DATABASE_URL=postgresql+asyncpg://codehive:codehive@localhost:5432/codehive

# PostgreSQL connection settings (used by docker-compose)
POSTGRES_USER=codehive
POSTGRES_PASSWORD=codehive
POSTGRES_DB=codehive

# ---------------------------------------------------------------------------
# Redis (optional -- empty = local in-process event bus)
# ---------------------------------------------------------------------------
# CODEHIVE_REDIS_URL=
# For Redis (requires Docker or external server):
CODEHIVE_REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# LLM Providers
# ---------------------------------------------------------------------------
# Codehive supports four providers. Claude and Codex work via their CLI tools
# (no API keys needed). OpenAI API and Z.ai need API keys.
#
# Provider      | Type | How it works           | Required env vars
# ------------- | ---- | ---------------------- | -----------------
# Claude        | CLI  | `claude` CLI subprocess | None (install `claude` CLI)
# Codex         | CLI  | `codex` CLI subprocess  | None (install `codex` CLI)
# OpenAI API    | API  | Direct API via SDK      | CODEHIVE_OPENAI_API_KEY
# Z.ai          | API  | Anthropic-compatible    | CODEHIVE_ZAI_API_KEY

# OpenAI API provider (for direct API access)
# CODEHIVE_OPENAI_API_KEY=sk-your-openai-key-here
# CODEHIVE_OPENAI_BASE_URL=https://api.openai.com

# Z.ai provider (Anthropic-compatible API)
# CODEHIVE_ZAI_API_KEY=sk-your-zai-key-here
# CODEHIVE_ZAI_BASE_URL=https://api.z.ai/api/anthropic

# Default model for Claude provider
# CODEHIVE_DEFAULT_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# GitHub integration
# ---------------------------------------------------------------------------
# CODEHIVE_GITHUB_DEFAULT_TOKEN=ghp_your-token-here

# ---------------------------------------------------------------------------
# Telegram bot
# ---------------------------------------------------------------------------
# CODEHIVE_TELEGRAM_BOT_TOKEN=your-bot-token
# CODEHIVE_TELEGRAM_CHAT_ID=your-chat-id

# --- Production Compose (docker-compose.prod.yml) ---
# When running with docker-compose.prod.yml, use container hostnames:
# CODEHIVE_DATABASE_URL=postgresql+asyncpg://codehive:codehive@postgres:5432/codehive
# CODEHIVE_REDIS_URL=redis://redis:6379/0
