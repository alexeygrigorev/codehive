# PostgreSQL connection settings (used by docker-compose)
POSTGRES_USER=codehive
POSTGRES_PASSWORD=codehive
POSTGRES_DB=codehive

# Application database URL (used by backend via CODEHIVE_ prefix)
# Set CODEHIVE_DATABASE_URL to override the default
DATABASE_URL=postgresql+asyncpg://codehive:codehive@localhost:5432/codehive
CODEHIVE_DATABASE_URL=postgresql+asyncpg://codehive:codehive@localhost:5432/codehive

# Redis URL (used by backend via CODEHIVE_ prefix)
# Set CODEHIVE_REDIS_URL to override the default
REDIS_URL=redis://localhost:6379/0
CODEHIVE_REDIS_URL=redis://localhost:6379/0
